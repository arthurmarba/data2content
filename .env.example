# Example environment variables for the project

# Public base URL of the application
NEXT_PUBLIC_APP_URL=https://example.com
NEXT_PUBLIC_GA_ID=G-XXXXXXXXXX
NEXT_PUBLIC_ANALYTICS_ENV=development

# Base URL for NextAuth (fallback for NEXT_PUBLIC_APP_URL)
NEXTAUTH_URL=https://example.com

# Stripe keys
STRIPE_SECRET_KEY=sk_live_xxx
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_live_xxx
STRIPE_WEBHOOK_SECRET=whsec_xxx
STRIPE_CONNECT_WEBHOOK_SECRET=whsec_connect

# Community / WhatsApp links
NEXT_PUBLIC_COMMUNITY_FREE_URL=https://chat.whatsapp.com/sua-comunidade-gratuita
NEXT_PUBLIC_COMMUNITY_VIP_URL=https://chat.whatsapp.com/seu-grupo-vip
NEXT_PUBLIC_WHATSAPP_TRIAL_URL=/planning/whatsapp
WHATSAPP_TRIAL_ENABLED=false
NEXT_PUBLIC_WHATSAPP_TRIAL_ENABLED=false
NEXT_PUBLIC_WHATSAPP_BOT_NUMBER=552120380975
WHATSAPP_TRIAL_EXPIRE_TEMPLATE=
WHATSAPP_TRIAL_UPSELL_URL=https://app.data2content.co/dashboard/billing/checkout
WHATSAPP_TRIAL_GRACE_MINUTES=5
WHATSAPP_TRIAL_CRON_LIMIT=50

STRIPE_PRICE_MONTHLY_BRL=price_xxx
STRIPE_PRICE_ANNUAL_BRL=price_xxx
STRIPE_PRICE_MONTHLY_USD=price_xxx
STRIPE_PRICE_ANNUAL_USD=price_xxx
STRIPE_COUPON_AFFILIATE10_ONCE_BRL=coupon_brl
STRIPE_COUPON_AFFILIATE10_ONCE_USD=coupon_usd
STRIPE_CONNECT_MODE=express
STRIPE_CONNECT_RETURN_URL=https://example.com/affiliate/connect/return
STRIPE_CONNECT_REFRESH_URL=https://example.com/affiliate/connect/refresh
AFFILIATE_COMMISSION_PERCENT=10
AFFILIATE_ATTRIBUTION_WINDOW_DAYS=90
CRON_SECRET=changeme

# Minimum redeem amounts per currency (in cents)
AFFILIATE_MIN_REDEEM_BRL=1000
AFFILIATE_MIN_REDEEM_USD=1000
REDEEM_MIN_EUR=1000

# --- OpenAI (optional) ---
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini
OPENAI_TEMP=0.7

# --- Planner themes mode ---
# flex  = keyword aparece naturalmente; não precisa iniciar a frase (recomendado)
# strict= cada pauta começa com a keyword
PLANNER_THEMES_MODE=flex

# --- Video Narrative (Mobile Strategic Profile) ---
# Gemini API
GEMINI_API_KEY=
VIDEO_NARRATIVE_GEMINI_MODEL=gemini-2.5-flash
VIDEO_NARRATIVE_GEMINI_FLASH_ENABLED=false
VIDEO_NARRATIVE_GEMINI_ALLOWLIST_ENABLED=false
VIDEO_NARRATIVE_GEMINI_ALLOWED_EMAILS=
VIDEO_NARRATIVE_GEMINI_ALLOWED_USER_IDS=

# Real Analysis (Feature Flags)
VIDEO_NARRATIVE_REAL_ANALYSIS_E2E_ENABLED=false
VIDEO_NARRATIVE_GEMINI_SMOKE_ENABLED=false

# Temporary Upload Storage (Cloudflare R2 / AWS S3 / Mock)
VIDEO_NARRATIVE_TEMP_UPLOAD_SESSION_ENABLED=false
VIDEO_NARRATIVE_REAL_UPLOAD_ENABLED=false
VIDEO_NARRATIVE_SIGNED_UPLOAD_ALLOWLIST_ENABLED=false
VIDEO_NARRATIVE_SIGNED_UPLOAD_ALLOWED_EMAILS=
VIDEO_NARRATIVE_SIGNED_UPLOAD_ALLOWED_USER_IDS=
VIDEO_NARRATIVE_TEMP_STORAGE_PROVIDER=local_mock
VIDEO_NARRATIVE_TEMP_UPLOAD_MAX_MB=500
VIDEO_NARRATIVE_TEMP_UPLOAD_TTL_MINUTES=60
VIDEO_NARRATIVE_TEMP_SIGNED_URL_TTL_SECONDS=300
VIDEO_NARRATIVE_TEMP_STORAGE_BUCKET=
VIDEO_NARRATIVE_TEMP_STORAGE_REGION=
VIDEO_NARRATIVE_TEMP_STORAGE_ENDPOINT=
