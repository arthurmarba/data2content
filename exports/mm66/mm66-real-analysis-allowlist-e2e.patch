+  it("bloqueia objectKey fora do padrão seguro", () => {
+    const result = validateVideoNarrativeRealAnalysisPayload({
+      ...validPayload,
+      temporaryUpload: { ...validPayload.temporaryUpload, objectKey: "bucket/public/video.mp4" },
+    });
