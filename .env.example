# Example environment variables for the project

# Public base URL of the application
NEXT_PUBLIC_APP_URL=https://example.com
NEXT_PUBLIC_GA_ID=G-XXXXXXXXXX
NEXT_PUBLIC_ANALYTICS_ENV=development

# Base URL for NextAuth (fallback for NEXT_PUBLIC_APP_URL)
NEXTAUTH_URL=https://example.com

# Stripe keys
STRIPE_SECRET_KEY=sk_live_xxx
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_live_xxx
STRIPE_WEBHOOK_SECRET=whsec_xxx
STRIPE_CONNECT_WEBHOOK_SECRET=whsec_connect

# Community / WhatsApp links
NEXT_PUBLIC_COMMUNITY_FREE_URL=https://chat.whatsapp.com/sua-comunidade-gratuita
NEXT_PUBLIC_COMMUNITY_VIP_URL=https://chat.whatsapp.com/seu-grupo-vip
NEXT_PUBLIC_WHATSAPP_TRIAL_URL=/planning/whatsapp
WHATSAPP_TRIAL_ENABLED=false
NEXT_PUBLIC_WHATSAPP_TRIAL_ENABLED=false
NEXT_PUBLIC_WHATSAPP_BOT_NUMBER=552120380975
WHATSAPP_TRIAL_EXPIRE_TEMPLATE=
WHATSAPP_TRIAL_UPSELL_URL=https://app.data2content.co/dashboard/billing/checkout
WHATSAPP_TRIAL_GRACE_MINUTES=5
WHATSAPP_TRIAL_CRON_LIMIT=50

# Price IDs dos NOVOS assinantes (padrão): BRL 97,00/mês · 890/ano | USD 19.40/mês · 179/ano
# Gerados por scripts/migrateStripePricing.ts (lookup_keys d2c_pro_new_*)
STRIPE_PRICE_MONTHLY_BRL=price_xxx
STRIPE_PRICE_ANNUAL_BRL=price_xxx
STRIPE_PRICE_MONTHLY_USD=price_xxx
STRIPE_PRICE_ANNUAL_USD=price_xxx
# Opcional: força o Product ao criar as prices (senão é derivado de STRIPE_PRICE_MONTHLY_BRL)
# STRIPE_PRODUCT_ID=prod_xxx
# Fallbacks de exibição quando as price IDs acima faltam (mantêm o site coerente):
# MONTHLY_PLAN_PRICE=97
# ANNUAL_PLAN_MONTHLY_PRICE=74.1667
# MONTHLY_PLAN_PRICE_USD=19.40
# ANNUAL_PLAN_YEAR_PRICE_USD=179
STRIPE_COUPON_AFFILIATE10_ONCE_BRL=coupon_brl
STRIPE_COUPON_AFFILIATE10_ONCE_USD=coupon_usd
STRIPE_CONNECT_MODE=express
STRIPE_CONNECT_RETURN_URL=https://example.com/affiliate/connect/return
STRIPE_CONNECT_REFRESH_URL=https://example.com/affiliate/connect/refresh
AFFILIATE_COMMISSION_PERCENT=10
AFFILIATE_ATTRIBUTION_WINDOW_DAYS=90
CRON_SECRET=changeme

# Minimum redeem amounts per currency (in cents)
AFFILIATE_MIN_REDEEM_BRL=1000
AFFILIATE_MIN_REDEEM_USD=1000
REDEEM_MIN_EUR=1000

# --- OpenAI (optional) ---
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini
OPENAI_TEMP=0.7
# Modelo usado pelo worker de classificação de conteúdo (default: gpt-4o-mini)
OPENAI_CLASSIFIER_MODEL=gpt-4o-mini
# ATENÇÃO: OPENAI_MODEL acima é um override GLOBAL — quando setado, ele substitui
# o mapeamento por intensidade do mapa (low=gpt-4o-mini, medium/high=gpt-4o).
# Com OPENAI_MODEL=gpt-4o-mini, a "leitura inaugural" (high) também roda em mini.
# Para dar teto de qualidade ao mapa sem mexer no resto, prefira os overrides finos:
# OPENAI_MAPA_HIGH_MODEL=gpt-4o
# OPENAI_MAPA_MEDIUM_MODEL=gpt-4o
# OPENAI_MAPA_LOW_MODEL=gpt-4o-mini

# --- Seleção de provider LLM (núcleo provider-agnóstico) ---
# Escolhe o provider primário por escopo; o outro vira fallback automático.
# Default (sem flag) = openai primário, gemini fallback (preserva o comportamento atual).
# Ativar Gemini Flash não exige deploy — basta setar a flag; reverter = remover.
#   LLM_PROVIDER            -> global (fallback de todos os escopos)
#   LLM_PROVIDER_MAPA       -> mapaSeed + resumo semanal do mapa (claudeService, weeklyMapSummary)
#   LLM_PROVIDER_AI         -> aiService (resumo de conversa, expertise, Q&A)
# Valores aceitos: "openai" | "gemini"
LLM_PROVIDER=
LLM_PROVIDER_MAPA=
LLM_PROVIDER_AI=
# Modelo Gemini usado pelo núcleo (default: gemini-2.5-flash)
GEMINI_MAPA_MODEL=gemini-2.5-flash
# gemini-2.5-flash é "thinking": tokens de raciocínio consomem o maxOutputTokens
# e podem TRUNCAR JSONs grandes (ex.: o mapa). Default do núcleo = 0 (thinking
# desligado) → orçamento de saída previsível, mais rápido e barato para extração.
# Use -1 para reativar o thinking automático; >0 para um teto fixo.
GEMINI_THINKING_BUDGET=0

# --- Content classification worker (QStash) ---
# OBRIGATÓRIAS em produção: sem AMBAS, posts ingeridos via API ficam presos em
# classificationStatus='pending' para sempre (o enqueue em metricActions.ts vira
# no-op silencioso) e o card "Sua Audiência" / rankings por território ficam sem dados.
# QSTASH_TOKEN: token do Upstash QStash (cliente que publica a tarefa de classificação).
QSTASH_TOKEN=
# URL pública do worker que classifica o conteúdo (POST /api/worker/classify-content).
CLASSIFICATION_WORKER_URL=
# Chaves de verificação de assinatura QStash no worker (recebe as tarefas).
QSTASH_CURRENT_SIGNING_KEY=
QSTASH_NEXT_SIGNING_KEY=

# --- Planner themes mode ---
# flex  = keyword aparece naturalmente; não precisa iniciar a frase (recomendado)
# strict= cada pauta começa com a keyword
PLANNER_THEMES_MODE=flex

# --- Video Narrative (Mobile Strategic Profile) ---
# Gemini API
GEMINI_API_KEY=
VIDEO_NARRATIVE_GEMINI_MODEL=gemini-2.5-flash
VIDEO_NARRATIVE_GEMINI_TIMEOUT_MS=90000
VIDEO_NARRATIVE_GEMINI_MAX_OUTPUT_TOKENS=4096
VIDEO_NARRATIVE_GEMINI_FLASH_ENABLED=false
VIDEO_NARRATIVE_GEMINI_ALLOWLIST_ENABLED=false
VIDEO_NARRATIVE_GEMINI_ALLOWED_EMAILS=
VIDEO_NARRATIVE_GEMINI_ALLOWED_USER_IDS=

# Diagnóstico V2 UX (Apple Health-style page — replaces old Perfil shell when =1)
DIAGNOSTICO_V2_ENABLED=0

# ── PRODUCTION LAUNCH FLAGS (all three must be "1" / "true" in production) ──
# Enables Gemini as the video analysis provider (vs. mock/stub)
VIDEO_NARRATIVE_GEMINI_PROVIDER_ENABLED=false
# Allows Pro users to run real Gemini video analysis (daily + monthly limits apply)
VIDEO_NARRATIVE_REAL_ANALYSIS_ALLOW_PREMIUM_BETA=false

# Real Analysis (Feature Flags)
VIDEO_NARRATIVE_REAL_ANALYSIS_E2E_ENABLED=false
VIDEO_NARRATIVE_GEMINI_SMOKE_ENABLED=false

# Temporary Upload Storage (Cloudflare R2 / AWS S3 / Mock)
VIDEO_NARRATIVE_TEMP_UPLOAD_SESSION_ENABLED=false
VIDEO_NARRATIVE_REAL_UPLOAD_ENABLED=false
VIDEO_NARRATIVE_SIGNED_UPLOAD_ALLOWLIST_ENABLED=false
VIDEO_NARRATIVE_SIGNED_UPLOAD_ALLOWED_EMAILS=
VIDEO_NARRATIVE_SIGNED_UPLOAD_ALLOWED_USER_IDS=
VIDEO_NARRATIVE_TEMP_STORAGE_PROVIDER=local_mock
VIDEO_NARRATIVE_TEMP_UPLOAD_MAX_MB=500
VIDEO_NARRATIVE_TEMP_UPLOAD_TTL_MINUTES=60
VIDEO_NARRATIVE_TEMP_SIGNED_URL_TTL_SECONDS=300
VIDEO_NARRATIVE_TEMP_STORAGE_BUCKET=
VIDEO_NARRATIVE_TEMP_STORAGE_REGION=
VIDEO_NARRATIVE_TEMP_STORAGE_ENDPOINT=
